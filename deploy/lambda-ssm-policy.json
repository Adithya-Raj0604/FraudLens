{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadAnthropicKey",
      "Effect": "Allow",
      "Action": "ssm:GetParameter",
      "Resource": "arn:aws:ssm:us-east-1:__ACCOUNT_ID__:parameter/fraudlens/anthropic-api-key"
    },
    {
      "Sid": "DecryptViaSSM",
      "Effect": "Allow",
      "Action": "kms:Decrypt",
      "Resource": "*",
      "Condition": {
        "StringEquals": { "kms:ViaService": "ssm.us-east-1.amazonaws.com" }
      }
    }
  ]
}
